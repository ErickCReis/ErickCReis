{
  "name": "erickcreis",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --parallel dev:astro dev:api",
    "dev:astro": "bun --bun astro dev --host",
    "dev:api": "bun --watch server/index.ts",
    "tokens:sync": "bun scripts/token-usage-sync.ts",
    "db:generate": "drizzle-kit generate",
    "lint": "oxlint --fix --type-aware && oxfmt && tsgo --noEmit && astro check",
    "build": "bun --bun astro build && bun build ./server/index.ts --compile --outfile myserver",
    "start": "NODE_ENV=production bun server/index.ts"
  },
  "dependencies": {
    "@astrojs/markdown-satteri": "0.3.2",
    "@astrojs/mdx": "7.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/solid-js": "7.0.0",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/cron": "^1.4.2",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/static": "^1.4.10",
    "@solid-primitives/mouse": "^2.1.6",
    "@solid-primitives/scheduled": "^1.5.3",
    "@solid-primitives/timer": "^1.4.4",
    "@solid-primitives/tween": "^1.4.1",
    "astro": "7.0.3",
    "astro-og-seo": "^0.1.2",
    "clsx": "^2.1.1",
    "drizzle-orm": "1.0.0-rc.3",
    "elysia": "^1.4.29",
    "lucide-astro": "^0.556.0",
    "nanoid": "^5.1.16",
    "resend": "^6.16.0",
    "satteri": "0.9.3",
    "solid-js": "^1.9.13",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "7.0.0-dev.20260626.1",
    "drizzle-kit": "1.0.0-rc.3",
    "isomorphic-mermaid": "^0.1.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "8.1.0"
  }
}
