{
  "name": "erickcreis",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --parallel dev:astro dev:api",
    "dev:astro": "bun --bun astro dev --host",
    "dev:api": "bun --watch server/index.ts",
    "codex:sync": "bun scripts/codex-sync.ts",
    "db:generate": "drizzle-kit generate",
    "lint": "oxlint --fix --type-aware && oxfmt && tsgo --noEmit && astro check",
    "build": "bun --bun astro build && bun build ./server/index.ts --compile --outfile myserver",
    "start": "NODE_ENV=production bun server/index.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.2",
    "@astrojs/solid-js": "6.0.1",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/static": "^1.4.7",
    "@solid-primitives/mouse": "^2.1.6",
    "@solid-primitives/scheduled": "^1.5.3",
    "@solid-primitives/timer": "^1.4.4",
    "@solid-primitives/tween": "^1.4.1",
    "astro": "6.0.7",
    "clsx": "^2.1.1",
    "drizzle-orm": "^1.0.0-beta.20",
    "elysia": "^1.4.28",
    "lucide-astro": "^0.556.0",
    "nanoid": "^5.1.7",
    "resend": "^6.10.0",
    "solid-js": "^1.9.11",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@typescript/native-preview": "7.0.0-dev.20260320.1",
    "drizzle-kit": "^1.0.0-beta.20",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "8.0.1"
  },
  "overrides": {
    "vite": "8.0.1"
  }
}
