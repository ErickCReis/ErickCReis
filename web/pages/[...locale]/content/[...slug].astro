---
import { getCollection } from "astro:content";
import { render } from "astro:content";
import { ArrowLeft, ArrowRight } from "lucide-astro";
import { fade } from "astro:transitions";
import { t, resolveLocale } from "virtual:translate";
import LocaleSwitcher from "@web/components/locale-switcher.astro";
import {
  getBlogEntries,
  getBlogEntry,
  getBlogStaticPaths,
  getBlogViewKey,
} from "@web/lib/blog";
import { PostViewCounter } from "@web/islands/post-view-counter";
import BaseLayout from "@web/layouts/base-layout.astro";
import { getLocalizedPath } from "@web/i18n";

export async function getStaticPaths() {
  return getBlogStaticPaths(await getCollection("blog"), {
    includeScheduled: import.meta.env.MODE === "development",
  });
}

const { locale, slug } = Astro.props;
const includeScheduled = import.meta.env.MODE === "development";
const entries = await getCollection("blog");
const post = getBlogEntry(entries, slug, locale, {
  includeScheduled,
})!;

const posts = getBlogEntries(entries, locale, { includeScheduled }).sort(
  (left, right) => right.entry.data.date.getTime() - left.entry.data.date.getTime(),
);
const postIndex = posts.findIndex((entry) => entry.slug === slug);
const nextPost = postIndex > 0 ? posts[postIndex - 1] : undefined;
const previousPost = postIndex >= 0 ? posts[postIndex + 1] : undefined;

const dateFormatter = new Intl.DateTimeFormat(resolveLocale(locale), {
  day: "numeric",
  month: "short",
  timeZone: "UTC",
  year: "numeric",
});
const { Content } = await render(post);
const viewKey = getBlogViewKey(post);
const contentPath = getLocalizedPath(locale, "content");
---

<BaseLayout
  title={`${post.data.title} | Erick Reis`}
  description={post.data.description}
  lang={locale}
  seo={{
    type: "article",
    publishedTime: post.data.date,
  }}
>
  <main
    class="relative z-10 mx-auto min-h-svh w-full max-w-3xl px-4 py-12 md:min-h-dvh md:px-8"
    transition:animate={fade({ duration: "0.2s" })}
  >
    <article class="space-y-8 py-4">
      <header class="space-y-5">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <a
            href={getLocalizedPath(locale, "content")}
            class="inline-flex w-fit items-center gap-2 rounded-full border border-border/70 px-3 py-1 font-mono text-xxs tracking-wider uppercase transition-colors hover:border-foreground/50 hover:text-foreground"
          >
            <ArrowLeft aria-hidden="true" class="size-3.5 shrink-0" />
            <span>{t(locale, "All posts")}</span>
          </a>
          <LocaleSwitcher locale={locale} path={`content/${slug}`} />
        </div>

        <section
          id={`post-header-${locale}-${slug}`}
          class="space-y-4"
          transition:name={`post-header-${slug}`}
        >
          <h1
            class="font-serif text-2xl leading-tight tracking-wide md:text-3xl"
          >
            {post.data.title}
          </h1>
          <p
            class="max-w-2xl text-sm leading-relaxed text-muted-foreground md:text-base"
          >
            {post.data.description}
          </p>
          <div
            class="flex flex-wrap gap-3 font-mono text-xxs tracking-widest text-muted-foreground uppercase"
          >
            <span>{dateFormatter.format(post.data.date)}</span>
            <PostViewCounter client:only="solid-js" slug={viewKey} />
          </div>
          <div class="flex flex-wrap gap-2" aria-label={t(locale, "Tags")}>
            {post.data.tags.map((tag) => (
              <a
                href={`${contentPath}?tag=${encodeURIComponent(tag)}`}
                class="rounded-full border border-border/70 px-2.5 py-1 font-mono text-xxs text-primary transition-colors hover:border-primary/60 hover:text-foreground"
              >
                #{tag}
              </a>
            ))}
          </div>
        </section>
      </header>

      <div class="h-px w-full bg-border/70"></div>

      <div class="prose prose-invert max-w-none prose-a:text-primary">
        <Content />
      </div>

      {
        (previousPost || nextPost) && (
          <nav
            class="grid gap-3 border-t border-border/70 pt-8 sm:grid-cols-2"
            aria-label={t(locale, "Post navigation")}
          >
            {previousPost ? (
              <a
                href={getLocalizedPath(locale, `content/${previousPost.slug}`)}
                rel="prev"
                class="group flex min-h-28 flex-col gap-3 rounded-lg border border-border/70 p-4 transition-colors hover:border-primary/60"
              >
                <span class="flex items-center gap-2 font-mono text-xxs tracking-wider text-muted-foreground uppercase transition-colors group-hover:text-primary">
                  <ArrowLeft aria-hidden="true" class="size-3.5 shrink-0" />
                  {t(locale, "Previous post")}
                </span>
                <span class="font-serif text-lg leading-snug tracking-wide">
                  {previousPost.entry.data.title}
                </span>
              </a>
            ) : (
              <span class="hidden sm:block" aria-hidden="true" />
            )}

            {nextPost && (
              <a
                href={getLocalizedPath(locale, `content/${nextPost.slug}`)}
                rel="next"
                class="group flex min-h-28 flex-col items-end gap-3 rounded-lg border border-border/70 p-4 text-right transition-colors hover:border-primary/60"
              >
                <span class="flex items-center gap-2 font-mono text-xxs tracking-wider text-muted-foreground uppercase transition-colors group-hover:text-primary">
                  {t(locale, "Next post")}
                  <ArrowRight aria-hidden="true" class="size-3.5 shrink-0" />
                </span>
                <span class="font-serif text-lg leading-snug tracking-wide">
                  {nextPost.entry.data.title}
                </span>
              </a>
            )}
          </nav>
        )
      }
    </article>
  </main>
</BaseLayout>
