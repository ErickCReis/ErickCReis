---
import { t, locales, defaultLocale } from "virtual:translate";
import LocaleSwitcher from "@web/components/locale-switcher.astro";
import { HomeLiveOverlay } from "@web/islands/home-live-overlay";
import BaseLayout from "@web/layouts/base-layout.astro";
import { getLocalizedPath } from "@web/i18n";

export function getStaticPaths() {
  return locales.map((locale) => ({
    params: {
      locale: locale === defaultLocale ? undefined : locale,
    },
    props: {
      locale,
    },
  }));
}

const { locale } = Astro.props;
const homeDescription = t(
  locale,
  "TypeScript engineer building React and Next.js products, microfrontends, and realtime applications.",
);

const featuredProjects = [
  {
    index: "01",
    name: "glim-node",
    label: t(locale, "Toolkit / Backend"),
    summary: t(locale, "Type-safe tooling for Node.js services."),
    technologies: ["TypeScript", "Hono", "Node.js", "CLI"],
    href: "https://github.com/ErickCReis/glim-node",
  },
  {
    index: "02",
    name: "local-box",
    label: t(locale, "Product / Infra"),
    summary: t(locale, "Self-hosted file sharing and sync experiments."),
    technologies: ["TypeScript", "React", "TanStack Start", "Convex"],
    href: "https://github.com/ErickCReis/local-box",
  },
  {
    index: "03",
    name: "car-league",
    label: t(locale, "Game / Multiplayer"),
    summary: t(
      locale,
      "A multiplayer game built around realtime interactions.",
    ),
    technologies: ["TypeScript", "React", "Three.js", "Cloudflare"],
    href: "https://github.com/ErickCReis/car-league",
  },
  {
    index: "04",
    name: "tabnews",
    label: t(locale, "Contributions"),
    summary: t(
      locale,
      "Open source issues and improvements across frontend, backend and tooling.",
    ),
    technologies: ["Next.js", "React", "Node.js"],
    href: "https://github.com/filipedeschamps/tabnews.com.br/issues?q=author%3AErickCReis",
  },
];
---

<BaseLayout
  title={t(locale, "Erick Reis | Portfolio")}
  description={homeDescription}
  lang={locale}
>
  <HomeLiveOverlay client:only="solid-js" />
  <main class="relative z-10">
    <section
      class="relative mx-auto flex min-h-svh w-full max-w-6xl flex-col px-4 pt-16 pb-0 sm:px-8 sm:pt-20 md:min-h-dvh"
    >
      <div class="flex justify-end">
        <LocaleSwitcher locale={locale} />
      </div>

      <div
        class="flex flex-1 items-start pt-6 sm:pt-10 md:items-center md:pt-0"
      >
        <div class="max-w-3xl space-y-8">
          <div class="space-y-6">
            <h1
              class="max-w-3xl font-serif text-5xl leading-none tracking-wide md:text-7xl"
            >
              Erick Reis
            </h1>
            <p class="max-w-xl text-base leading-8 text-muted-foreground">
              {homeDescription}
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a
              href={getLocalizedPath(locale, "content")}
              class="inline-flex h-10 items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 font-medium text-primary-foreground transition-colors hover:brightness-110"
            >
              {t(locale, "Content")}
            </a>
            <a
              href="https://github.com/erickcreis"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-10 items-center justify-center whitespace-nowrap rounded-md border border-input bg-background/80 px-4 py-2 font-medium backdrop-blur transition-colors hover:bg-accent hover:text-accent-foreground"
            >
              GitHub
            </a>
          </div>
        </div>
      </div>

      <div class="relative z-10 pt-6 pb-12">
        <p
          class="flex items-center gap-2 text-xs font-medium uppercase tracking-widest text-primary/70"
        >
          <span>{t(locale, "Featured projects")}</span>
          <span aria-hidden="true" class="text-primary/85">↓</span>
        </p>
      </div>
    </section>

    <section
      id="selected-work"
      class="relative z-10 mx-auto -mt-10 w-full max-w-6xl px-4 pb-14 sm:px-8 sm:pb-16"
    >
      <div class="pt-6">
        <div class="space-y-1">
          {
            featuredProjects.map((project) => (
              <a
                href={project.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group grid gap-2 border-b border-white/8 py-5 transition-colors md:grid-cols-[2rem_minmax(0,1fr)]"
              >
                <span class="pt-2 text-xs tracking-widest text-muted-foreground md:w-8 md:shrink-0">
                  {project.index}
                </span>
                <div>
                  <div class="flex flex-wrap items-baseline justify-between gap-3">
                    <h2 class="font-serif text-2xl tracking-wide text-foreground transition-colors group-hover:text-primary">
                      {project.name}
                    </h2>
                    <span class="text-xxs uppercase tracking-widest text-muted-foreground">
                      {project.label}
                    </span>
                  </div>
                  <p class="text-sm leading-7 text-muted-foreground">
                    {project.summary}
                  </p>
                  <div class="flex flex-wrap gap-2 pt-3">
                    {project.technologies.map((technology) => (
                      <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-1 text-xxs uppercase tracking-wider text-secondary-foreground">
                        {technology}
                      </span>
                    ))}
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
