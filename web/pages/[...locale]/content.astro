---
import { getCollection } from "astro:content";
import { ArrowLeft } from "lucide-astro";
import { fade } from "astro:transitions";
import { t, locales, defaultLocale, resolveLocale } from "virtual:translate";
import LocaleSwitcher from "@web/components/locale-switcher.astro";
import { ContentViewCountsHydrator } from "@web/islands/content-view-counts-hydrator";
import { ContentTelemetryToggle } from "@web/islands/content-telemetry-toggle";
import { getBlogEntries, getBlogViewKey } from "@web/lib/blog";
import BaseLayout from "@web/layouts/base-layout.astro";
import { getLocalizedPath } from "@web/i18n";

export function getStaticPaths() {
  return locales.map((locale) => ({
    params: {
      locale: locale === defaultLocale ? undefined : locale,
    },
    props: {
      locale,
    },
  }));
}

const { locale } = Astro.props;
const includeScheduled = import.meta.env.MODE === "development";

const dateFormatter = new Intl.DateTimeFormat(resolveLocale(locale), {
  day: "numeric",
  month: "short",
  timeZone: "UTC",
  year: "numeric",
});

const posts = getBlogEntries(await getCollection("blog"), locale, {
  includeScheduled,
})
  .map(({ slug, entry }) => ({
    ...entry.data,
    viewKey: getBlogViewKey(entry),
    href: getLocalizedPath(locale, `content/${slug}`),
  }))
  .sort((a, b) => b.date.getTime() - a.date.getTime());

const tags = [...new Set(posts.flatMap((post) => post.tags))].sort((a, b) =>
  a.localeCompare(b),
);
const contentPath = getLocalizedPath(locale, "content");
---

<BaseLayout
  title={t(locale, "Content | Erick Reis")}
  description={t(
    locale,
    "Notes on frontend engineering, systems work, and the decisions behind the build.",
  )}
  lang={locale}
>
  <main
    class="relative z-10 mx-auto min-h-svh w-full max-w-3xl px-4 py-12 md:min-h-dvh md:px-8"
    transition:animate={fade({ duration: "0.2s" })}
  >
    <section class="space-y-8 py-4">
      <header class="space-y-6">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <a
            href={getLocalizedPath(locale)}
            class="inline-flex w-fit items-center gap-2 rounded-full border border-border/70 px-3 py-1 font-mono text-xxs tracking-wider uppercase transition-colors hover:border-foreground/50 hover:text-foreground"
          >
            <ArrowLeft aria-hidden="true" class="size-3.5 shrink-0" />
            <span>{t(locale, "Back")}</span>
          </a>

          <div class="flex items-center gap-3">
            <LocaleSwitcher locale={locale} path="content" />
            <ContentTelemetryToggle client:only="solid-js" />
          </div>
        </div>
        <h1 class="font-serif text-4xl tracking-wide md:text-5xl">
          {t(locale, "Content")}
        </h1>

        {
          tags.length > 0 && (
            <nav
              class="relative z-40 flex flex-wrap gap-2"
              aria-label={t(locale, "Available tags")}
              data-tag-filter
            >
              <a
                href={contentPath}
                data-tag-link=""
                class="rounded-full border border-border/70 bg-background/80 px-2.5 py-1 font-mono text-xxs text-muted-foreground backdrop-blur-sm transition-colors hover:border-primary/60 hover:text-foreground"
              >
                {t(locale, "All posts")}
              </a>
              {tags.map((tag) => (
                <a
                  href={`${contentPath}?tag=${encodeURIComponent(tag)}`}
                  data-tag-link={tag}
                  class="rounded-full border border-border/70 bg-background/80 px-2.5 py-1 font-mono text-xxs text-muted-foreground backdrop-blur-sm transition-colors hover:border-primary/60 hover:text-foreground"
                >
                  #{tag}
                </a>
              ))}
            </nav>
          )
        }
      </header>

      {
        posts.length === 0 ? (
          <p class="text-sm text-muted-foreground md:text-base">
            {t(locale, "No posts published yet.")}
          </p>
        ) : (
          <>
            <ContentViewCountsHydrator
              client:only="solid-js"
              slugs={posts.map((post) => post.viewKey)}
            />
            <section class="space-y-3" aria-label={t(locale, "Blog posts")}>
              {posts.map((post) => (
                <article
                  class="border-b border-border/60 pb-4 last:border-b-0 last:pb-0"
                  data-post
                  data-tags={JSON.stringify(post.tags)}
                >
                  <a href={post.href} class="group block py-1">
                    <section
                      id={`post-header-${post.viewKey}`}
                      class="space-y-4"
                      transition:name={`post-header-${post.viewKey}`}
                    >
                      <h2 class="font-serif text-2xl leading-tight tracking-wide transition-colors group-hover:text-primary md:text-3xl">
                        {post.title}
                      </h2>
                      <p class="max-w-2xl text-sm leading-relaxed text-muted-foreground md:text-base">
                        {post.description}
                      </p>
                      <div class="flex flex-wrap gap-3 font-mono text-xxs tracking-widest text-muted-foreground uppercase">
                        <span>{dateFormatter.format(post.date)}</span>
                        <span data-post-view-count={post.viewKey}>
                          -- {t(locale, "views")}
                        </span>
                      </div>
                      <div class="flex flex-wrap gap-2" aria-label={t(locale, "Tags")}>
                        {post.tags.map((tag) => (
                          <span class="font-mono text-xxs text-primary">#{tag}</span>
                        ))}
                      </div>
                    </section>
                  </a>
                </article>
              ))}
              <p
                class="hidden py-4 text-sm text-muted-foreground md:text-base"
                data-tag-empty
              >
                {t(locale, "No posts found for this tag.")}
              </p>
            </section>
          </>
        )
      }
    </section>
  </main>
</BaseLayout>

<script>
  function initializeTagFilter() {
    const filter = document.querySelector<HTMLElement>("[data-tag-filter]");

    if (!filter || filter.dataset.initialized) {
      return;
    }

    filter.dataset.initialized = "true";

    const posts = [...document.querySelectorAll<HTMLElement>("[data-post]")];
    const emptyState = document.querySelector<HTMLElement>("[data-tag-empty]");
    const tagLinks = [...filter.querySelectorAll<HTMLAnchorElement>("[data-tag-link]")];

    const normalize = (value: string) => value.trim().toLocaleLowerCase();

    function applyTagFilter(value: string, updateUrl = true) {
      const query = normalize(value);
      let visiblePosts = 0;

      for (const post of posts) {
        const tags = JSON.parse(post.dataset.tags ?? "[]") as string[];
        const visible = !query || tags.some((tag) => normalize(tag) === query);
        post.classList.toggle("hidden", !visible);
        visiblePosts += Number(visible);
      }

      emptyState?.classList.toggle("hidden", visiblePosts > 0);

      for (const link of tagLinks) {
        link.setAttribute(
          "aria-current",
          normalize(link.dataset.tagLink ?? "") === query ? "true" : "false",
        );
        link.classList.toggle(
          "border-primary",
          normalize(link.dataset.tagLink ?? "") === query,
        );
        link.classList.toggle(
          "text-foreground",
          normalize(link.dataset.tagLink ?? "") === query,
        );
      }

      if (updateUrl) {
        const url = new URL(window.location.href);
        if (query) {
          url.searchParams.set("tag", value.trim());
        } else {
          url.searchParams.delete("tag");
        }
        window.history.replaceState({}, "", url);
      }
    }

    const initialTag = new URL(window.location.href).searchParams.get("tag") ?? "";
    applyTagFilter(initialTag, false);

    for (const link of tagLinks) {
      link.addEventListener("click", (event) => {
        event.preventDefault();
        applyTagFilter(link.dataset.tagLink ?? "");
      });
    }
  }

  initializeTagFilter();
  document.addEventListener("astro:page-load", initializeTagFilter);
</script>
