---
import { getCollection } from "astro:content";
import { ArrowLeft } from "lucide-astro";
import { fade } from "astro:transitions";
import { t, locales, defaultLocale, resolveLocale } from "virtual:translate";
import LocaleSwitcher from "@web/components/locale-switcher.astro";
import { ContentViewCountsHydrator } from "@web/islands/content-view-counts-hydrator";
import { ContentTelemetryToggle } from "@web/islands/content-telemetry-toggle";
import { getBlogEntries, getBlogViewKey } from "@web/lib/blog";
import BaseLayout from "@web/layouts/base-layout.astro";
import { getLocalizedPath } from "@web/i18n";

export function getStaticPaths() {
  return locales.map((locale) => ({
    params: {
      locale: locale === defaultLocale ? undefined : locale,
    },
    props: {
      locale,
    },
  }));
}

const { locale } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat(resolveLocale(locale), {
  day: "numeric",
  month: "short",
  timeZone: "UTC",
  year: "numeric",
});

const posts = getBlogEntries(await getCollection("blog"), locale)
  .map(({ slug, entry }) => ({
    ...entry.data,
    viewKey: getBlogViewKey(entry),
    href: getLocalizedPath(locale, `content/${slug}`),
  }))
  .sort((a, b) => b.date.getTime() - a.date.getTime());
---

<BaseLayout
  title={t(locale, "Content | Erick Reis")}
  description={t(
    locale,
    "Notes on frontend engineering, systems work, and the decisions behind the build.",
  )}
  lang={locale}
>
  <main
    class="relative z-10 mx-auto min-h-svh w-full max-w-3xl px-4 py-12 md:min-h-dvh md:px-8"
    transition:animate={fade({ duration: "0.2s" })}
  >
    <section class="space-y-8 py-4">
      <header class="space-y-6">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <a
            href={getLocalizedPath(locale)}
            class="inline-flex w-fit items-center gap-2 rounded-full border border-border/70 px-3 py-1 font-mono text-xxs tracking-wider uppercase transition-colors hover:border-foreground/50 hover:text-foreground"
          >
            <ArrowLeft aria-hidden="true" class="size-3.5 shrink-0" />
            <span>{t(locale, "Back")}</span>
          </a>

          <div class="flex items-center gap-3">
            <LocaleSwitcher locale={locale} path="content" />
            <ContentTelemetryToggle client:only="solid-js" />
          </div>
        </div>
        <h1 class="font-serif text-4xl tracking-wide md:text-5xl">
          {t(locale, "Content")}
        </h1>
      </header>

      {
        posts.length === 0 ? (
          <p class="text-sm text-muted-foreground md:text-base">
            {t(locale, "No posts published yet.")}
          </p>
        ) : (
          <>
            <ContentViewCountsHydrator
              client:only="solid-js"
              slugs={posts.map((post) => post.viewKey)}
            />
            <section class="space-y-3" aria-label={t(locale, "Blog posts")}>
              {posts.map((post) => (
                <article class="border-b border-border/60 pb-4 last:border-b-0 last:pb-0">
                  <a href={post.href} class="group block py-1">
                    <section
                      id={`post-header-${post.viewKey}`}
                      class="space-y-4"
                      transition:name={`post-header-${post.viewKey}`}
                    >
                      <h2 class="font-serif text-2xl leading-tight tracking-wide transition-colors group-hover:text-primary md:text-3xl">
                        {post.title}
                      </h2>
                      <p class="max-w-2xl text-sm leading-relaxed text-muted-foreground md:text-base">
                        {post.description}
                      </p>
                      <div class="flex flex-wrap gap-3 font-mono text-xxs tracking-widest text-muted-foreground uppercase">
                        <span>{dateFormatter.format(post.date)}</span>
                        <span data-post-view-count={post.viewKey}>
                          -- {t(locale, "views")}
                        </span>
                      </div>
                    </section>
                  </a>
                </article>
              ))}
            </section>
          </>
        )
      }
    </section>
  </main>
</BaseLayout>
