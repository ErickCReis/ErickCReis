---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/base-layout.astro";

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "short",
  year: "numeric",
});

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: {
      slug: post.id,
    },
    props: {
      post,
    },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | Erick Reis`}
  description={post.data.description}
>
  <main class="relative z-10 mx-auto min-h-svh w-full max-w-3xl px-4 py-12 md:min-h-dvh md:px-8">
    <article class="space-y-8 py-4">
      <header class="space-y-5">
        <a
          href="/content"
          class="inline-flex w-fit items-center gap-2 rounded-full border border-border/70 px-3 py-1 font-mono text-xs tracking-[0.12em] uppercase transition-colors hover:border-foreground/50 hover:text-foreground"
        >
          <span aria-hidden="true">←</span>
          <span>All posts</span>
        </a>

        <div class="space-y-4">
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="rounded-full border border-border/80 px-2.5 py-1 font-mono text-[0.62rem] tracking-[0.14em] text-muted-foreground uppercase">
                {tag}
              </span>
            ))}
          </div>

          <h1 class="font-serif text-4xl leading-tight tracking-wide md:text-6xl">
            {post.data.title}
          </h1>
          <p class="max-w-2xl text-sm leading-relaxed text-muted-foreground md:text-base">
            {post.data.description}
          </p>
        </div>

        <div class="flex flex-wrap gap-3 font-mono text-[0.68rem] tracking-[0.18em] text-muted-foreground uppercase">
          <span>{dateFormatter.format(post.data.date)}</span>
          {post.data.readingTime && <span>{post.data.readingTime}</span>}
        </div>
      </header>

      <div class="h-px w-full bg-border/70"></div>

      <div class="content-body space-y-5 text-base leading-8 text-foreground/92">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .content-body :global(p) {
    margin: 0;
  }

  .content-body :global(a) {
    color: hsl(var(--primary));
    text-decoration: underline;
    text-decoration-color: rgb(255 255 255 / 0.16);
    text-underline-offset: 0.2em;
  }

  .content-body :global(strong) {
    color: hsl(var(--foreground));
    font-weight: 600;
  }

  .content-body :global(code) {
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: 0.45rem;
    background: rgb(255 255 255 / 0.04);
    padding: 0.1rem 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.9em;
  }
</style>
