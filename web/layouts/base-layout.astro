---
import { Font } from "astro:assets";
import OgSeo from "astro-og-seo/OgSeo.astro";
import { defaultLocale, locales, resolveLocale } from "virtual:translate";
import OgImageCard from "@web/components/og-image-card.astro";
import SitePresenceScript from "@web/components/site-presence-script.astro";
import { getLocalizedPath } from "@web/i18n";

import "@web/styles/site.css";

interface Props {
  title: string;
  description?: string;
  lang?: string;
  seo?: {
    type?: "website" | "article";
    publishedTime?: Date | string;
    modifiedTime?: Date | string;
    robots?: string;
  };
}

const { title, description, lang = "en-US", seo } = Astro.props;
const locale = resolveLocale(lang);
const pathname = Astro.url.pathname.replace(/\/+$/g, "") || "/";
const canonicalPath = pathname === "/" ? "/" : `${pathname}/`;
const pageType = seo?.type ?? "website";

function getContentPath(path: string) {
  if (locale === defaultLocale) return path === "/" ? "" : path.slice(1);

  const prefix = `/${locale}`;

  return path === prefix ? "" : path.slice(prefix.length + 1);
}

const contentPath = getContentPath(pathname);
function getAlternateUrl(alternateLocale: string) {
  const localizedPath = getLocalizedPath(alternateLocale, contentPath);
  const canonicalLocalizedPath =
    localizedPath === "/" ? "/" : `${localizedPath.replace(/\/+$/g, "")}/`;

  return new URL(canonicalLocalizedPath, Astro.site!);
}

const alternates = [
  ...locales.map((alternateLocale) => ({
    href: getAlternateUrl(alternateLocale),
    hreflang: resolveLocale(alternateLocale),
  })),
  {
    href: getAlternateUrl(defaultLocale),
    hreflang: "x-default",
  },
];
const alternateLocales = locales
  .filter((alternateLocale) => resolveLocale(alternateLocale) !== locale)
  .map(resolveLocale);
const article =
  pageType === "article" && seo?.publishedTime
    ? {
        publishedTime: seo.publishedTime,
        modifiedTime: seo.modifiedTime,
      }
    : undefined;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <OgSeo
      title={title}
      description={description}
      canonical={canonicalPath}
      lang={locale}
      robots={seo?.robots}
      alternates={alternates}
      alternateLocales={alternateLocales}
      type={pageType}
      article={article}
      generatedImageAlt={title}
    >
      <OgImageCard
        slot="image"
        title={title}
        description={description}
        locale={locale}
        type={pageType}
        publishedTime={seo?.publishedTime}
      />
    </OgSeo>
    <meta name="theme-color" content="#070b13" />
    <Font cssVariable="--font-family-sans" preload />
    <Font cssVariable="--font-family-serif" preload />
    <Font cssVariable="--font-family-mono" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <slot name="head" />
  </head>
  <body>
    <SitePresenceScript />
    <div class="site-background" aria-hidden="true"></div>
    <slot />
  </body>
</html>

<style>
  .site-background {
    position: fixed;
    inset: -20svh 0;
    z-index: -1;
    pointer-events: none;
    background-color: hsl(var(--background));
    background-repeat: no-repeat;
    background-image:
      radial-gradient(circle at 12% 8%, rgb(72 99 145 / 30%), transparent 42%),
      radial-gradient(
        circle at 88% 92%,
        rgb(112 180 171 / 20%),
        transparent 46%
      ),
      linear-gradient(180deg, rgb(7 12 22 / 92%), rgb(7 11 19 / 98%));
  }
</style>
