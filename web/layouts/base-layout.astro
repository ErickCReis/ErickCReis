---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import { resolveLocale } from "virtual:translate";

import "@web/styles/site.css";

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description, lang = "en-US" } = Astro.props;
const locale = resolveLocale(lang);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {description && <meta name="description" content={description} />}
    <Font cssVariable="--font-family-sans" preload />
    <Font cssVariable="--font-family-serif" preload />
    <Font cssVariable="--font-family-mono" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
    <ClientRouter />
  </head>
  <body>
    <div class="site-background" aria-hidden="true"></div>
    <slot />
  </body>
</html>

<style>
  .site-background {
    position: fixed;
    inset: -20svh 0;
    z-index: -1;
    pointer-events: none;
    background-color: hsl(var(--background));
    background-repeat: no-repeat;
    background-image:
      radial-gradient(circle at 12% 8%, rgb(72 99 145 / 30%), transparent 42%),
      radial-gradient(
        circle at 88% 92%,
        rgb(112 180 171 / 20%),
        transparent 46%
      ),
      linear-gradient(180deg, rgb(7 12 22 / 92%), rgb(7 11 19 / 98%));
  }
</style>
