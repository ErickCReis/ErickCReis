---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import { defaultLocale, locales, resolveLocale } from "virtual:translate";
import SitePresenceScript from "@web/components/site-presence-script.astro";
import { getLocalizedPath } from "@web/i18n";

import "@web/styles/site.css";

interface Props {
  title: string;
  description?: string;
  lang?: string;
  seo?: {
    type?: "website" | "article";
    publishedTime?: Date | string;
    modifiedTime?: Date | string;
    robots?: string;
  };
}

const { title, description, lang = "en-US", seo } = Astro.props;
const locale = resolveLocale(lang);
const site = Astro.site;
const pathname = Astro.url.pathname.replace(/\/+$/g, "") || "/";

function getContentPath(pathname: string, locale: string) {
  if (locale === defaultLocale) {
    return pathname === "/" ? "" : pathname.slice(1);
  }

  const localePrefix = `/${locale}`;

  if (pathname === localePrefix) {
    return "";
  }

  return pathname.slice(localePrefix.length + 1);
}

function toOpenGraphLocale(locale: string) {
  return locale.replace("-", "_");
}

const contentPath = getContentPath(pathname, locale);
const canonicalUrl = site ? new URL(pathname, site).toString() : undefined;
const alternateUrls = site
  ? locales.map((alternateLocale) => ({
      href: new URL(getLocalizedPath(alternateLocale, contentPath), site).toString(),
      hreflang: resolveLocale(alternateLocale),
      ogLocale: toOpenGraphLocale(alternateLocale),
    }))
  : [];
const defaultAlternateUrl = site
  ? new URL(getLocalizedPath(defaultLocale, contentPath), site).toString()
  : undefined;
const {
  type: pageType = "website",
  robots = "index,follow",
  publishedTime,
  modifiedTime,
} = seo ?? {};
const articlePublishedTime = publishedTime ? new Date(publishedTime).toISOString() : undefined;
const articleModifiedTime = modifiedTime ? new Date(modifiedTime).toISOString() : articlePublishedTime;
const ogLocale = toOpenGraphLocale(locale);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {description && <meta name="description" content={description} />}
    <meta name="robots" content={robots} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {
      alternateUrls.map(({ href, hreflang }) => (
        <link rel="alternate" hreflang={hreflang} href={href} />
      ))
    }
    {defaultAlternateUrl && (
      <link rel="alternate" hreflang="x-default" href={defaultAlternateUrl} />
    )}
    <meta property="og:site_name" content="Erick Reis" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:type" content={pageType} />
    <meta property="og:locale" content={ogLocale} />
    {
      alternateUrls
        .filter(({ hreflang }) => hreflang !== locale)
        .map(({ ogLocale }) => (
          <meta property="og:locale:alternate" content={ogLocale} />
        ))
    }
    {articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <Font cssVariable="--font-family-sans" preload />
    <Font cssVariable="--font-family-serif" preload />
    <Font cssVariable="--font-family-mono" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
    <ClientRouter />
  </head>
  <body>
    <SitePresenceScript />
    <div class="site-background" aria-hidden="true"></div>
    <slot />
  </body>
</html>

<style>
  .site-background {
    position: fixed;
    inset: -20svh 0;
    z-index: -1;
    pointer-events: none;
    background-color: hsl(var(--background));
    background-repeat: no-repeat;
    background-image:
      radial-gradient(circle at 12% 8%, rgb(72 99 145 / 30%), transparent 42%),
      radial-gradient(
        circle at 88% 92%,
        rgb(112 180 171 / 20%),
        transparent 46%
      ),
      linear-gradient(180deg, rgb(7 12 22 / 92%), rgb(7 11 19 / 98%));
  }
</style>
